{
    "name": "kraz/messenger-workflow",
    "description": "Symfony bundle for working with enterprise integration patterns.",
    "keywords": [
        "CQS",
        "CQRS",
        "command",
        "query",
        "outbox",
        "inbox",
        "deduplication",
        "ddd"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Krasen Borisov",
            "email": "krasen.borisov@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-redis": "*",
        "doctrine/orm": "^3.6",
        "jwage/phpamqplib-messenger": "^0.10",
        "symfony/console": "^8.1",
        "symfony/doctrine-messenger": "^8.1",
        "symfony/messenger": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/uid": "^8.1",
        "symfony/yaml": "^8.1",
        "webmozart/assert": "^2.4"
    },
    "require-dev": {
        "cweagans/composer-patches": "^2.0",
        "doctrine/doctrine-bundle": "^3.2",
        "phpunit/phpunit": "^13.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/property-access": "^8.1",
        "symfony/property-info": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Kraz\\MessengerWorkflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kraz\\MessengerWorkflow\\Tests\\": "tests/",
            "Contracts\\": "tests/Fixture/Contracts/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "cweagans/composer-patches": true
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "patches": {
            "jwage/phpamqplib-messenger": {
                "Add support for Symfony 8.1": "patches/composer/jwage/phpamqplib-messenger/patch-121"
            }
        }
    }
}
