{
    "name": "kraz/messenger-workflow",
    "description": "Symfony bundle for working with enterprise integration patterns.",
    "keywords": [
        "CQS",
        "CQRS",
        "command",
        "query",
        "outbox",
        "inbox",
        "deduplication",
        "ddd"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Krasen Borisov",
            "email": "krasen.borisov@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-redis": "*",
        "doctrine/orm": "^3.6",
        "symfony/console": "^8.1",
        "symfony/doctrine-messenger": "^8.1",
        "symfony/messenger": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/uid": "^8.1",
        "webmozart/assert": "^2.4"
    },
    "require-dev": {
        "doctrine/coding-standard": "^14.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/phpunit-bridge": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Kraz\\MessengerWorkflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kraz\\MessengerWorkflow\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable"
}
